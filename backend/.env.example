# AWS (DynamoDB + S3 only — Bedrock not used)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Aurora PostgreSQL
AURORA_DSN=postgresql://codebase:password@your-aurora-cluster.rds.amazonaws.com:5432/codebase

# DynamoDB
DYNAMODB_TABLE_AST_CHUNKS=codebase-ast-chunks

# S3 (FAISS index persistence)
S3_BUCKET=codebase-faiss-indexes

# Auth
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Groq (LLM — llama-3.3-70b-versatile)
GROQ_API_KEY=your-groq-api-key

# Embeddings (TF-IDF max_features cap — actual FAISS dim derived from corpus vocabulary)
EMBED_DIMENSIONS=8192

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
